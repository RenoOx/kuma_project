# Runtime
NODE_ENV=development
PORT=3000

# Databases
# Main database used by `npm run dev`, scripts, and smoke tests.
DATABASE_URL=postgres://user:password@localhost:5432/kuma
# Separate database used when NODE_ENV=test (vitest), so tests can TRUNCATE
# safely without nuking dev data.
TEST_DATABASE_URL=postgres://user:password@localhost:5432/kuma_test

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# OpenAI / LLM
OPENAI_API_KEY=

# WhatsApp / Baileys — optional. When set, the dev server boots a Baileys
# client for this business and persists session under ./sessions/{BUSINESS_ID}/
BUSINESS_ID=

# Google Calendar OAuth — optional at boot, required to run the OAuth flow.
# Create an OAuth 2.0 web app credential at console.cloud.google.com and
# whitelist this exact redirect URI: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
