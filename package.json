{
  "name": "@vamvu/kuma",
  "version": "0.1.0",
  "description": "Kuma — multi-tenant WhatsApp assistant for service businesses",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "smoke:db": "tsx scripts/smoke-db.ts",
    "smoke:conversation": "tsx scripts/smoke-conversation.ts",
    "smoke:modules": "tsx scripts/smoke-modules.ts",
    "smoke:llm": "tsx scripts/smoke-llm.ts",
    "smoke:tools": "tsx scripts/smoke-tools.ts",
    "smoke:settings": "tsx scripts/smoke-settings.ts",
    "smoke:google": "tsx scripts/smoke-google.ts",
    "smoke:owner": "tsx scripts/smoke-owner.ts",
    "smoke:notifications": "tsx scripts/smoke-notifications.ts",
    "create:business": "tsx scripts/create-test-business.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@whiskeysockets/baileys": "^6.7.23",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "googleapis": "^173.0.0",
    "hono": "^4.12.24",
    "nanoid": "^5.1.11",
    "openai": "^6.42.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "qrcode-terminal": "^0.12.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.2",
    "vitest": "^4.1.8"
  }
}
